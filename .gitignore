# ============================================================
# Root .gitignore for xx_github repository
# ============================================================

# ── Python ────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/
*.so

# ── Environment / Secrets (NEVER commit these) ────────────
.env
.env.*
*.env
!.env.example
!.env.template
!.env.sample

# ── Node.js ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/cache

# ── Next.js ───────────────────────────────────────────────
.next/
out/

# ── Build outputs ─────────────────────────────────────────
dist/
build/

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.desktop

# ── Media / Generated audio files ─────────────────────────
*.wav
*.mp3
*.mp4
*.m4a
*.avi
*.mkv
*.mov

# ── Database files ────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── IDE / Editor ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/

# ── C / C++ build artifacts ───────────────────────────────
*.o
*.out
*.a
*.lib
CMakeCache.txt
CMakeFiles/
cmake-build-*/
Makefile
